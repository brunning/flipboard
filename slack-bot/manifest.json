{
  "display_information": {
    "name": "Flipboard",
    "description": "Render messages on a split-flap sign as animated GIFs",
    "background_color": "#1a1a1a"
  },
  "features": {
    "bot_user": {
      "display_name": "Flipboard",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/flipboard",
        "description": "Render a message on a split-flap sign",
        "usage_hint": "your message here",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": ["commands", "chat:write", "files:write"]
    }
  },
  "settings": {
    "socket_mode_enabled": true,
    "org_deploy_enabled": false,
    "token_rotation_enabled": false
  }
}
