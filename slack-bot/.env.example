# Copy this file to `.env` and fill in the two tokens you get from
# api.slack.com/apps. See README.md for the click-by-click instructions.

# Bot User OAuth Token (Settings → Install App). Starts with xoxb-
SLACK_BOT_TOKEN=xoxb-

# App-Level Token with `connections:write` scope
# (Settings → Basic Information → App-Level Tokens). Starts with xapp-
SLACK_APP_TOKEN=xapp-

# Local HTTP port used internally to serve the web app to the headless
# browser. You don't need to expose this. Change only if 3000 is in use.
PORT=3000
